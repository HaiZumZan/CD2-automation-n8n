    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || $input.first().json.text || '';\n\nconst match = raw.match(/\\[[\\s\\S]*\\]/);\nif (!match) {\n  return [{ json: { error: 'Không parse được JSON', raw } }];\n}\n\nconst flashcards = JSON.parse(match[0]);\nreturn [{ json: { status: 'success', mode: 'flashcard', data: flashcards } }];"
      },
