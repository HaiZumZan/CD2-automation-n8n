    {
      "parameters": {
        "promptType": "define",
        "text": "Hãy tạo flashcard từ tài liệu được cung cấp.",
        "options": {
          "systemPromptTemplate": "Bạn là một công cụ tạo flashcard. Đọc nội dung tài liệu dưới đây và tạo ra đúng 10 flashcard.\n\nCONTEXT:\n{context}\n\nQUY TẮC BẮT BUỘC:\n1. Chỉ trả về JSON array thuần túy, không có markdown, không có giải thích.\n2. Bắt đầu bằng [ và kết thúc bằng ]\n3. Mỗi item có đúng 2 key: \"term\" và \"definition\"\n4. \"definition\" viết bằng tiếng Việt, ngắn gọn 2-3 câu.\n\n[{\"term\": \"...\",\"definition\": \"...\"},{\"term\": \"...\",\"definition\": \"...\"}]"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainRetrievalQa",
      "typeVersion": 1.7,
