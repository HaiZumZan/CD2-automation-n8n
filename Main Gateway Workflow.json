    {
      "parameters": {
        "jsCode": "// 1. Lấy mã từ AI Agent\nlet rawCode = $input.item.json.output || \"\";\n\n// 2. Làm sạch Markdown và khoảng trắng\nlet cleanCode = rawCode.replace(/```mermaid|```/gi, \"\").trim();\n\n// 3. Xử lý \"dọn dẹp\" cú pháp:\n// - Xóa các dấu hai chấm (:) dư thừa ở cuối các dòng\n// - Xóa mọi chữ \"mindmap\" đi lạc ở đầu\nlet body = cleanCode\n    .replace(/:(\\s*$)/gm, \"\") \n    .replace(/^(\\s*mindmap\\s*)+/gi, \"\")\n    .trim();\n\n// 4. Gắn duy nhất một từ khóa mindmap chuẩn\nlet finalCode = \"mindmap\\n\" + body;\n\n// 5. Mã hóa Base64 an toàn cho URL\nlet base64 = Buffer.from(finalCode).toString('base64')\n    .replace(/\\+/g, '-')\n    .replace(/\\//g, '_')\n    .replace(/=+$/, '');\n\nreturn {\n  mermaid_base64: base64,\n  original_code: finalCode\n};"
      },
